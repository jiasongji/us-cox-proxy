#!/sbin/openrc-run
name="microsocks"
description="Lightweight SOCKS5 Proxy (multi-instance)"
command="/usr/local/bin/microsocks"
depend() { need net; after firewall; }

start() {
    local ACC="/etc/microsocks/accounts.conf"
    [ -f "$ACC" ] || { eerror "No accounts.conf"; return 1; }
    ebegin "Starting microsocks instances"
    local n=0
    while IFS=' ' read -r PORT USER PASS; do
        [ -z "$PORT" ] && continue
        echo "$PORT" | grep -q '^#' && continue
        start-stop-daemon --start --background --make-pidfile \
            --pidfile "/run/microsocks.${PORT}.pid" \
            --exec /usr/local/bin/microsocks -- -q -p "${PORT}" -u "${USER}" -P "${PASS}"
        n=$((n+1))
    done < "$ACC"
    eend 0 "Started ${n} instances"
}

stop() {
    ebegin "Stopping microsocks instances"
    for pf in /run/microsocks.*.pid; do
        [ -f "$pf" ] || continue
        start-stop-daemon --stop --pidfile "$pf" --exec /usr/local/bin/microsocks 2>/dev/null
        rm -f "$pf"
    done
    eend 0
}

status() {
    local found=0
    for pf in /run/microsocks.*.pid; do
        [ -f "$pf" ] || continue
        if kill -0 "$(cat "$pf" 2>/dev/null)" 2>/dev/null; then
            found=1
        fi
    done
    [ "$found" -eq 1 ]
}
